msgstr "碎镜"

#. ~ Description for {'str': 'Shattered Mirror'}
#: .\monsters\winter zeds\sq_monster_spells.json
msgid "Summons a weaker ice clone of itself."
msgstr "召唤自身较弱的冰克隆体。"

#: .\monsters\winter zeds\sq_monster_spells.json
msgid "Ice Blast"
msgstr "冰爆"

#. ~ Description for {'str': 'Ice Blast'}
#: .\monsters\winter zeds\sq_monster_spells.json
