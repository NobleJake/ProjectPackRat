msgid_plural "frost submachineguns"
msgstr[0] "冰霜冲锋枪"

#: .\monsters\winter zeds\sq_monster_spells.json
msgid ""
"Used to give frost-submachinegun-shooting monster a specific degree of "
"inaccuracy. If you encounter one of these in the wild, it's a bug."
msgstr "用于给发射冰霜冲锋枪的怪物提供特定程度的不准确性。如果在野外遇到这个，那是bug。"


#: .\monsters\winter zeds\sq_monster_spells.json
msgid "frost blast"
msgid_plural "frost blasts"
msgstr[0] "冰霜冲击"

#: .\monsters\winter zeds\sq_monster_spells.json
