#. ~ Description for Forked tongue serum
#: .\mutations\item.json
msgid ""
"A special mutagenic serum designed to give you a single mutation. Gain a "
"forked tongue."
msgstr "一种特殊的诱变血清，旨在赋予你单一突变。获得分叉的舌头。"

#: .\mutations\item.json
msgid "Bat wings serum"
msgid_plural "Bat wings serums"
msgstr[0] "蝙蝠翼血清"

#. ~ Description for Bat wings serum
#: .\mutations\item.json
msgid ""
"A special mutagenic serum designed to give you a single mutation. Gain a "
"pair of leathery wings like that of a bat."
msgstr "一种特殊的诱变血清，旨在赋予你单一突变。获得一对蝙蝠般的皮膜翅膀。"

#: .\mutations\item.json
msgid "Butterfly wings serum"
msgid_plural "Butterfly wings serums"
msgstr[0] "蝴蝶翼血清"

#. ~ Description for Butterfly wings serum
#: .\mutations\item.json
msgid ""
"A special mutagenic serum designed to give you a single mutation. Gain the "
"wings of a pretty butterfly."
msgstr "一种特殊的诱变血清，旨在赋予你单一突变。获得美丽蝴蝶的翅膀。"

#: .\mutations\item.json
msgid "Pale serum"
msgid_plural "Pale serums"
msgstr[0] "苍白血清"

#. ~ Description for Pale serum
#: .\mutations\item.json
msgid ""
"A special mutagenic serum designed to give you a single mutation. Get pale "
