msgid_plural "sprinter skeletons (on)"
msgstr[0] "疾跑外骨骼（开启）"

#. ~ Description for {'str': 'sprinter skeleton (on)', 'str_pl': 'sprinter
#. skeletons (on)'}
#: .\items\item_common\sq_cargo_frame.json
